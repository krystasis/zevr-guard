{
  "name": "zevr-guard",
  "version": "1.0.0",
  "description": "See who your browser is talking to in real-time. Visualize trackers and block dangerous connections.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:data && tsc -b --noEmit && vite build",
    "build:data": "tsx scripts/build-rules.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "mmdb-lib": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
